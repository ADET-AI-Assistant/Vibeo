{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "api/groq.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/huggingface.js",
      "use": "@vercel/node"
    },
    {
      "src": "backend/vercel_app.py",
      "use": "@vercel/python",
      "config": { "maxDuration": 60 }
    }
  ],
  "routes": [
    {
      "src": "/fanart-api/(.*)",
      "dest": "https://webservice.fanart.tv/v3/$1"
    },
    {
      "src": "/api/groq",
      "dest": "api/groq.js"
    },
    {
      "src": "/api/huggingface",
      "dest": "api/huggingface.js"
    },
    {
      "src": "/api/v1/(.*)",
      "dest": "backend/vercel_app.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "backend/vercel_app.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "backend/static/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}